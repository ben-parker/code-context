{
  "openapi": "3.0.1",
  "info": {
    "title": "CodeContext API",
    "description": "Local code context API for LLMs - provides dependency graph and code relationships",
    "contact": {
      "name": "CodeContext Team",
      "url": "https://github.com/you/codecontext"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:7999",
      "description": "Local CodeContext server"
    }
  ],
  "paths": {
    "/api/status": {
      "get": {
        "tags": [
          "codecontext"
        ],
        "summary": "Get API status",
        "description": "Returns comprehensive system health and debugging information.",
        "operationId": "GetStatus",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/context/complete": {
      "get": {
        "tags": [
          "codecontext"
        ],
        "summary": "Get complete context for an identifier",
        "description": "Returns comprehensive context information for a code construct. Searches by name or file path. Without 'type' parameter, searches across all entity types and returns best match or multiple matches. With 'type' parameter, searches only within specified type. Returns array of matches to handle ambiguity.",
        "operationId": "GetCompleteContext",
        "parameters": [
          {
            "name": "identifier",
            "in": "query",
            "description": "Canonical returned identifier, name, or repository-relative/absolute file path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by type (Class, Method, Interface, Property, etc.)",
            "schema": {
              "type": "string",
              "default": null
            }
          },
          {
            "name": "depth",
            "in": "query",
            "description": "How many relationship levels to traverse (0-10)",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "includeTests",
            "in": "query",
            "description": "Whether to include test-related information",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "includeContent",
            "in": "query",
            "description": "Whether to include file content snippets",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "exact",
            "in": "query",
            "description": "Exact matching; omit for exact-first matching with substring fallback",
            "schema": {
              "type": "boolean",
              "default": null
            }
          },
          {
            "name": "includeRelated",
            "in": "query",
            "description": "Whether to include loosely related same-file/namespace symbols",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "includeMetrics",
            "in": "query",
            "description": "Whether to include heuristic code metrics",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "maxMatches",
            "in": "query",
            "description": "Maximum ambiguous candidate summaries to return (1-50)",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 5
            }
          },
          {
            "name": "maxRelationships",
            "in": "query",
            "description": "Maximum entries returned per relationship list (1-100)",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 10
            }
          },
          {
            "name": "maxCallSites",
            "in": "query",
            "description": "Maximum locations returned per aggregated relationship (0-100)",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 3
            }
          },
          {
            "name": "maxTestFiles",
            "in": "query",
            "description": "Maximum test files returned; zero is count-only (0-100)",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 5
            }
          },
          {
            "name": "maxTestMethods",
            "in": "query",
            "description": "Maximum test methods returned per file; zero is count-only (0-100)",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 5
            }
          },
          {
            "name": "expandAmbiguous",
            "in": "query",
            "description": "Expand bounded ambiguous matches instead of returning summaries",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "containingType",
            "in": "query",
            "description": "Filter members by containing type",
            "schema": {
              "type": "string",
              "default": null
            }
          },
          {
            "name": "namespace",
            "in": "query",
            "description": "Filter by exact namespace or module",
            "schema": {
              "type": "string",
              "default": null
            }
          },
          {
            "name": "signature",
            "in": "query",
            "description": "Filter by exact signature",
            "schema": {
              "type": "string",
              "default": null
            }
          },
          {
            "name": "sourceFile",
            "in": "query",
            "description": "Filter by repository-relative or absolute source file",
            "schema": {
              "type": "string",
              "default": null
            }
          },
          {
            "name": "view",
            "in": "query",
            "description": "Response shape: compact (default) or full",
            "schema": {
              "type": "string",
              "default": "compact"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/CompactContextResponse"
                    },
                    {
                      "$ref": "#/components/schemas/CompleteContextResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/context/multi": {
      "post": {
        "tags": [
          "codecontext"
        ],
        "summary": "Get context for multiple identifiers",
        "description": "Returns context for multiple code constructs as a round-trip optimization. It reduces HTTP requests, not response-token size.",
        "operationId": "GetMultipleContext",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MultiContextRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/CompactContextResponse"
                      }
                    },
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/CompleteContextResponse"
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/index/refresh": {
      "post": {
        "tags": [
          "codecontext"
        ],
        "summary": "Refresh the code index",
        "description": "Triggers a re-parse of the specified file or the entire codebase. If path is provided, only that file is refreshed synchronously. If path is omitted, a full background rescan starts (202) and the response carries an operationId observable via /api/status; returns 409 if a scan is already in progress.",
        "operationId": "RefreshIndex",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "description": "Path to the file to refresh. If omitted, performs full scan.",
            "schema": {
              "type": "string",
              "default": null
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshFileResponseDto"
                }
              }
            }
          },
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshStartedResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "409": {
            "description": "Conflict"
          }
        }
      }
    },
    "/api/syntax-tree": {
      "post": {
        "tags": [
          "codecontext"
        ],
        "summary": "Get a language-native syntax tree",
        "description": "Returns an on-demand, parser-specific syntax tree for an indexed file. Use the normalized context endpoints for cross-language relationships; use this endpoint for exact syntax, tokens, nesting, and language-specific constructs.",
        "operationId": "GetNativeSyntaxTree",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NativeSyntaxTreeRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NativeSyntaxTreeResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "409": {
            "description": "Conflict"
          },
          "501": {
            "description": "Not Implemented"
          },
          "503": {
            "description": "Service Unavailable"
          }
        }
      }
    },
    "/healthz": {
      "get": {
        "tags": [
          "codecontext"
        ],
        "summary": "Liveness probe",
        "description": "Returns 200 as soon as the HTTP host is accepting requests. Use /api/status to determine whether indexing has completed.",
        "operationId": "Healthz",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthzResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/shutdown": {
      "post": {
        "tags": [
          "codecontext"
        ],
        "summary": "Gracefully stop this instance",
        "description": "Requests a graceful shutdown of this CodeContext instance. Requires the target instance's instanceId as a query parameter. The instance unregisters itself from the instance registry on exit.",
        "operationId": "Shutdown",
        "parameters": [
          {
            "name": "instanceId",
            "in": "query",
            "schema": {
              "type": "string",
              "default": null
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ShutdownResponseDto"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/api/schema": {
      "get": {
        "tags": [
          "codecontext"
        ],
        "summary": "Get OpenAPI 3.0 specification",
        "description": "Returns the OpenAPI 3.0 specification for the CodeContext API",
        "operationId": "GetOpenApiSchema",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
